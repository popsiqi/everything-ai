{
  "name": "everything-ai",
  "version": "1.0.1",
  "description": "Turn any product into an AI product in 5 minutes. Loading becomes Thinking. Spinner becomes 🧠. The ultimate satire on 'AI everywhere'.",
  "main": "dist/everything-ai.js",
  "module": "dist/everything-ai.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/everything-ai.es.js",
      "require": "./dist/everything-ai.js",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/react.es.js",
      "require": "./dist/react.js",
      "types": "./dist/react.d.ts"
    },
    "./vue": {
      "import": "./dist/vue.es.js",
      "require": "./dist/vue.js",
      "types": "./dist/vue.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "rm -rf dist && tsc --emitDeclarationOnly && vite build",
    "test": "vitest",
    "test:run": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "loading",
    "thinking",
    "整活",
    "satire"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=16.8.0",
    "vue": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "jsdom": "^29.0.2",
    "react": "^19.2.5",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0",
    "vue": "^3.5.32"
  }
}
